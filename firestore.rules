rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidService(data) {
      return data.keys().hasAll(['name', 'price', 'type']) &&
             data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.type in ['boosting', 'coaching'];
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'serviceId', 'date', 'timeSlot', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.serviceId is string &&
             data.date is string &&
             data.timeSlot is string &&
             data.status in ['pending', 'confirmed', 'completed', 'cancelled'] &&
             data.createdAt is number;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['user', 'admin'];
    }

    // Collection Rules
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin() && isValidService(incoming());
    }

    match /bookings/{bookingId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isValidBooking(incoming());
      allow update: if (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == 'cancelled') || isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidUserProfile(incoming()) && (incoming().role == existing().role || isAdmin());
      allow create: if isSignedIn() && isValidUserProfile(incoming()) && incoming().role == 'user';
    }
    
    // Admin list check
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
